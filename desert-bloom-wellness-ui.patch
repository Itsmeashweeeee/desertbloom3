diff --git a/style.css b/style.css
index 3333333..4444444 100644
--- a/style.css
+++ b/style.css
@@ -999,3 +999,91 @@
+
+/* Wellness tracker */
+.wellness-card {
+  margin: 18px 0 14px;
+  padding: 16px;
+  border-radius: 20px;
+  background: rgba(255, 248, 239, 0.92);
+  border: 1px solid rgba(176, 128, 89, 0.14);
+  box-shadow: 0 10px 24px rgba(85, 62, 43, 0.08);
+}
+
+.wellness-row {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+}
+
+.wellness-row + .wellness-row {
+  margin-top: 14px;
+  padding-top: 14px;
+  border-top: 1px solid rgba(176, 128, 89, 0.14);
+}
+
+.wellness-row-flow {
+  align-items: flex-start;
+}
+
+.wellness-label {
+  font-family: 'Lato', sans-serif;
+  font-size: 0.98rem;
+  font-weight: 700;
+  color: #5e4737;
+}
+
+.wellness-hint {
+  margin-top: 2px;
+  font-size: 0.84rem;
+  color: #8b6f5c;
+}
+
+.water-controls {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+}
+
+.water-btn {
+  width: 38px;
+  height: 38px;
+  border: 0;
+  border-radius: 12px;
+  background: #e6efe5;
+  color: #44624a;
+  font-size: 1.25rem;
+  line-height: 1;
+  cursor: pointer;
+}
+
+.water-btn:active {
+  transform: scale(0.98);
+}
+
+.water-count {
+  min-width: 28px;
+  text-align: center;
+  font-size: 1.2rem;
+  font-weight: 700;
+  color: #5e4737;
+}
+
+.flow-select {
+  min-width: 120px;
+  padding: 10px 12px;
+  border-radius: 12px;
+  border: 1px solid rgba(176, 128, 89, 0.22);
+  background: #fff;
+  color: #5e4737;
+  font: inherit;
+}
+
+.cactus-glow {
+  filter: drop-shadow(0 0 18px rgba(255, 170, 120, 0.28));
+}
+
+@media (max-width: 480px) {
+  .wellness-row {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .water-controls,
+  .flow-select {
+    width: 100%;
+  }
+
+  .water-controls {
+    justify-content: flex-end;
+  }
+}
