+function getTodayWater() {
+  return waterIntake[todayStr()] || 0;
+}
+
+function setTodayWater(amount) {
+  const today = todayStr();
+  waterIntake[today] = Math.max(0, Math.min(24, amount));
+  save();
+  renderWellness();
+  renderHomeMood();
+  renderDesert();
+}
+
+function setTodayFlow(level) {
+  const today = todayStr();
+  flowLog[today] = level;
+  save();
+  renderWellness();
+  renderHomeMood();
+  renderDesert();
+}
+
+function getTodayFlow() {
+  return flowLog[todayStr()] || 'none';
+}
+
+function renderWellness() {
+  const waterCount = document.getElementById('water-count');
+  const flowSelect = document.getElementById('flow-input');
+  const flowText = document.getElementById('flow-today');
+  if (!waterCount || !flowSelect || !flowText) return;
+
+  const water = getTodayWater();
+  const flow = getTodayFlow();
+  const label = {
+    none: 'No flow',
+    light: 'Light flow',
+    medium: 'Medium flow',
+    heavy: 'Heavy flow'
+  };
+
+  waterCount.textContent = water;
+  flowSelect.value = flow;
+  flowText.textContent = label[flow] || 'No flow';
+}
+
+function renderHomeMood() {
+  const sub = document.getElementById('home-subtext');
+  if (!sub) return;
+
+  const water = getTodayWater();
+  const flow = getTodayFlow();
+  const done = doneTasks().length;
+  const total = tasks.length;
+
+  if (done > 0 && total > 0 && done === total) {
+    sub.textContent = 'Everything is checked off. The desert looks alive today.';
+    return;
+  }
+
+  if (water >= 8 && flow === 'heavy') {
+    sub.textContent = 'You are pushing through a heavy day and still taking care of yourself.';
+    return;
+  }
+
+  if (water >= 8) {
+    sub.textContent = 'Hydration is solid today. Your cactus looks a little happier.';
+    return;
+  }
+
+  if (flow === 'heavy') {
+    sub.textContent = 'Heavy day. Keep the list short and give yourself some room.';
+    return;
+  }
+
+  sub.textContent = 'Small check-ins still count. Keep going.';
+}
